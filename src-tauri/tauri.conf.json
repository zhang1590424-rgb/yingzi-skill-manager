{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "影子",
  "version": "0.1.0",
  "identifier": "local.skill-hub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "影子",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png"]
  }
}
